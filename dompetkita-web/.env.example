# Base URL of the DompetKita API used by the frontend.
#
# Leave this empty to use the built-in defaults:
#   - dev (Vite, :5173)   -> http://localhost:8003/api
#   - production / Docker  -> /api (same origin, proxied by nginx)
#
# Set it explicitly only if your backend runs somewhere else, e.g.:
#   VITE_API_BASE=http://localhost:8003/api
VITE_API_BASE=
